        <source>Quarantined skills</source>
      </trans-unit>
      <trans-unit id="quarantine.back" resname="quarantine.back">
        <source>Back to overview</source>
      </trans-unit>
      <trans-unit id="quarantine.intro" resname="quarantine.intro">
        <source>These skills are hidden and will NOT run — either quarantined automatically by the security scan (danger-level finding) or disabled manually. Nothing here is deleted. Review each skill's findings, then release the ones you trust; released skills stay flagged in the catalogue so the findings remain visible.</source>
      </trans-unit>
      <trans-unit id="quarantine.col.reason" resname="quarantine.col.reason">
