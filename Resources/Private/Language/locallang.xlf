      <trans-unit id="module.headline" resname="module.headline">
        <source>Agent Skills</source>
      </trans-unit>
      <trans-unit id="security.blocked.title" resname="security.blocked.title">
        <source>Skill execution is blocked on this installation</source>
      </trans-unit>
      <trans-unit id="security.blocked.hint" resname="security.blocked.hint">
        <source>Skills send editorial content to an AI runner and may execute a local CLI. They are therefore restricted to local DDEV installations running in Development context. Managing and editing skills is still possible.</source>
      </trans-unit>
      <trans-unit id="security.local.title" resname="security.local.title">
        <source>Local development installation detected</source>
      </trans-unit>
      <trans-unit id="security.local.text" resname="security.local.text">
        <source>Skill execution is enabled (Development context + DDEV). Remember: skill runs send record content to the configured AI runner. Review skills from third-party repositories before running them, and never disable the environment guard on shared or production systems.</source>
      </trans-unit>
