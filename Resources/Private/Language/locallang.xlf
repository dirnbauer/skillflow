      </trans-unit>
      <trans-unit id="review.quarantined.help" resname="review.quarantined.help">
        <source>Hidden automatically because of a danger-level security finding. Not deleted — review the findings and unhide it (Access tab) if you trust it.</source>
      </trans-unit>
      <trans-unit id="review.quarantined.note" resname="review.quarantined.note">
        <source>Quarantined: this skill was hidden automatically because of a danger-level finding below. It was NOT deleted. Release it from the Quarantine screen (or clear "Disable" on the Access tab) after reviewing.</source>
      </trans-unit>
      <trans-unit id="quarantine.button" resname="quarantine.button">
        <source>Quarantine</source>
      </trans-unit>
